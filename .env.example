# LLM connection (OpenAI-compatible chat completions endpoint).
# Any of these can also be configured at runtime in the Settings app.
#
# Provider examples:
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1        LLM_MODEL=gpt-5.5
#   Anthropic:  LLM_BASE_URL=https://api.anthropic.com/v1     LLM_MODEL=claude-sonnet-4-5
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1     LLM_MODEL=anthropic/claude-sonnet-4.5
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1        LLM_MODEL=qwen3:32b
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5

# Optional: dedicated Whisper endpoint for podcast transcription and dictation fallback.
# When chat LLM points at Ollama/local models, transcription still uses OpenAI unless overridden.
# WHISPER_API_KEY=
# WHISPER_BASE_URL=https://api.openai.com/v1

# Server port (web dev server proxies /api here)
PORT=4600

# Where Arco stores apps, sessions, automations, workspace files, and databases
# (also holds users.json and auth-sessions.json — keep it out of git)
# ARCO_DATA_DIR=./data

# Set to 1 when serving over HTTPS so session cookies get the Secure flag.
# Required before exposing Arco beyond localhost.
# ARCO_SECURE_COOKIES=1

# Optional: comma-separated podcast RSS feed URLs for the Podcasts app (initial seed only).
# After first run, feeds are managed in the app and stored in data/podcast-feeds.json.
# PODCAST_RSS_FEEDS=https://feeds.npr.org/510289/podcast.xml,https://feeds.simplecast.com/EmVW7VGy

# Optional: auto-connect a Telegram bot on startup (Settings → Channels otherwise).
# Create one via @BotFather on Telegram (/newbot), then paste the token here.
# TELEGRAM_BOT_TOKEN=123456789:AA…

# Optional: GitHub OAuth app (one-click connect in Settings / Studio).
# Users can also connect with a personal access token without these.
# Create an OAuth App at https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=https://your-domain/api/github/oauth/callback
# ARCO_WEB_ORIGIN=https://your-domain

# Optional: server-wide token for cloning public repos when no user is connected.
# GITHUB_TOKEN=ghp_…
