# LLM connection (OpenAI-compatible chat completions endpoint).
# Any of these can also be configured at runtime in the Settings app.
#
# Provider examples:
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1        LLM_MODEL=gpt-5.5
#   Anthropic:  LLM_BASE_URL=https://api.anthropic.com/v1     LLM_MODEL=claude-sonnet-4-5
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1     LLM_MODEL=anthropic/claude-sonnet-4.5
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1        LLM_MODEL=qwen3:32b
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5

# Server port (web dev server proxies /api here)
PORT=4600

# Where Arco stores apps, sessions, automations, workspace files, and databases
# (also holds users.json and auth-sessions.json — keep it out of git)
# ARCO_DATA_DIR=./data

# Set to 1 when serving over HTTPS so session cookies get the Secure flag.
# Required before exposing Arco beyond localhost.
# ARCO_SECURE_COOKIES=1

# Optional: auto-connect a Telegram bot on startup (Settings → Channels otherwise).
# Create one via @BotFather on Telegram (/newbot), then paste the token here.
# TELEGRAM_BOT_TOKEN=123456789:AA…
