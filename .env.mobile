# Mobile shell — force MobileShell + default emulator API via Vite proxy host
VITE_ARCO_SHELL_PROFILE=mobile
# Bundled Capacitor APK (no dev server URL) — user picks server at first run
VITE_ARCO_MOBILE_BUNDLED=1
# Uncomment and set for static builds without server profile UI:
# VITE_ARCO_API_URL=http://10.0.2.2:4600
