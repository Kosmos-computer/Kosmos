{
  "name": "@arco/desktop",
  "private": true,
  "version": "0.1.12",
  "description": "Arco OS desktop shell — Electron wrapper around the Node server and Vite-built UI.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.cjs",
    "icon": "node scripts/generate-icon.mjs",
    "predev": "npm run icon",
    "prestart": "npm run icon",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "pack": "npm run build && node scripts/prepare-update-token.mjs && node scripts/validate-packaging.mjs && node scripts/stage-packaging.mjs && node scripts/verify-packaging.mjs --staged --smoke && electron-builder --dir",
    "dist": "npm run build && node scripts/prepare-update-token.mjs && node scripts/validate-packaging.mjs && node scripts/stage-packaging.mjs && node scripts/verify-packaging.mjs --staged --smoke && electron-builder",
    "dist:publish": "npm run build && node scripts/prepare-update-token.mjs && node scripts/validate-packaging.mjs && node scripts/stage-packaging.mjs && node scripts/verify-packaging.mjs --staged --smoke && electron-builder --publish always",
    "release:version": "node scripts/next-desktop-version.mjs",
    "release:should-ship": "node scripts/should-release-desktop.mjs",
    "release:publish": "node scripts/publish-release.mjs",
    "verify": "node scripts/verify-packaging.mjs --staged --smoke",
    "verify:app": "node scripts/verify-packaging.mjs --app \"release/mac-arm64/Kosmos.app\" --smoke --skip-build-check",
    "setup:local-models": "node scripts/setup-local-models.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "build": {
    "electronVersion": "43.1.0",
    "appId": "com.arco.os",
    "productName": "Kosmos",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "npmArgs": [
      "--ignore-scripts"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "disableDefaultIgnoredFiles": true,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "pack-staging/arco",
        "to": "arco",
        "filter": [
          "**/*",
          "!node_modules{,/**/*}"
        ]
      },
      {
        "from": "pack-staging/arco/node_modules",
        "to": "arco/node_modules"
      },
      {
        "from": "build/update-gh-token",
        "to": "update-gh-token"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "signAndEditExecutable": true,
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Kosmos-computer",
        "repo": "Kosmos",
        "private": true,
        "releaseType": "draft"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.8.0"
  }
}
