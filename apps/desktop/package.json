{
  "name": "@arco/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Arco OS desktop shell — Electron wrapper around the Node server and Vite-built UI.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.cjs",
    "icon": "node scripts/generate-icon.mjs",
    "predev": "npm run icon",
    "prestart": "npm run icon",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "pack": "npm run build && node scripts/validate-packaging.mjs && node scripts/stage-packaging.mjs && node scripts/verify-packaging.mjs --staged --smoke && electron-builder --dir",
    "dist": "npm run build && node scripts/validate-packaging.mjs && node scripts/stage-packaging.mjs && node scripts/verify-packaging.mjs --staged --smoke && electron-builder",
    "verify": "node scripts/verify-packaging.mjs --staged --smoke",
    "verify:app": "node scripts/verify-packaging.mjs --app \"release/mac-arm64/Arco OS.app\" --smoke --skip-build-check",
    "setup:local-models": "node scripts/setup-local-models.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "build": {
    "electronVersion": "35.7.5",
    "appId": "com.arco.os",
    "productName": "Arco OS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "npmArgs": [
      "--ignore-scripts"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "disableDefaultIgnoredFiles": true,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "pack-staging/arco",
        "to": "arco"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.0"
  }
}
