{
  "id": "core.docs",
  "name": "Docs",
  "version": "0.1.0",
  "description": "Rich-text documents stored in the OS file store (os.files@1) as TipTap JSON. Swap Docs for any app implementing os.docs@1; your documents stay.",
  "icon": "file-text",
  "tier": "code",
  "entry": { "kind": "bundle", "path": "docs/dist" },
  "implements": ["os.docs@1"],
  "permissions": [
    { "kind": "contract", "id": "os.files@1", "access": "read" },
    { "kind": "contract", "id": "os.files@1", "access": "write" },
    { "kind": "contract", "id": "os.docs@1", "access": "read" },
    { "kind": "contract", "id": "os.docs@1", "access": "write" },
    { "kind": "shell", "features": ["notify"] }
  ],
  "events": { "subscribes": ["files.changed"] }
}
