{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arco OS",
  "version": "0.1.2",
  "identifier": "com.arco.os.tauri",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:4610",
    "beforeBuildCommand": "cd ../.. && npm run build",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Arco OS",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
