{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arco Models",
  "version": "0.1.0",
  "identifier": "com.arco.models",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:4620",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Arco Models",
        "width": 1120,
        "height": 760,
        "minWidth": 840,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
