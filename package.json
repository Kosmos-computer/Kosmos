{
  "name": "arco-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Arco OS — a generative AI operating system prototype. Desktop shell + agent that builds adaptive live apps.",
  "workspaces": [
    "model-manager",
    "packages/app-sdk",
    "packages/editor-kit",
    "apps/desktop",
    "apps/docs"
  ],
  "scripts": {
    "models": "npm run dev -w model-manager",
    "generate": "tsx scripts/generate-prompts.ts",
    "predev": "npm run make-i18n && npm run build:apps",
    "dev": "concurrently -n server,web -c yellow,cyan \"npm run dev:server\" \"npm run dev:web\"",
    "dev:all": "concurrently -n server,web,voice -c yellow,cyan,magenta \"npm run dev:server\" \"npm run dev:web\" \"npm run voice\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "voice": "cd voice-server && .venv/bin/python bot.py --host localhost --port 4630",
    "build:apps": "npm run build -w @arco/docs-app",
    "prebuild": "npm run make-i18n",
    "build": "npm run build:apps && vite build",
    "desktop": "npm run build && npm run start -w @arco/desktop",
    "dist:desktop": "npm run generate && npm run build && npm run dist -w @arco/desktop",
    "dist:desktop:publish": "npm run generate && npm run build && npm run dist:publish -w @arco/desktop",
    "verify:desktop": "npm run verify -w @arco/desktop",
    "verify:desktop:app": "npm run verify:app -w @arco/desktop",
    "version:sync": "node scripts/sync-desktop-version.mjs",
    "version:check": "node scripts/check-desktop-version.mjs",
    "setup:desktop:local-models": "npm run setup:local-models -w @arco/desktop",
    "desktop:dev": "concurrently -n web,desktop -c cyan,magenta \"npm run dev:web\" \"npm run dev -w @arco/desktop\"",
    "desktop:dev:all": "concurrently -n server,web,desktop -c yellow,cyan,magenta \"npm run dev:server\" \"npm run dev:web\" \"npm run dev -w @arco/desktop\"",
    "menubar-tasks:build": "cd apps/menubar-tasks && bash scripts/build-app.sh",
    "menubar-tasks": "npm run menubar-tasks:build && open apps/menubar-tasks/ArcoMenubarTasks.app",
    "menubar-tasks:auth": "tsx scripts/menubar-auth.mts",
    "start": "NODE_ENV=production tsx server/index.ts",
    "setup": "tsx scripts/setup.mts",
    "setup:check": "tsx scripts/setup.mts --check",
    "postinstall": "tsx scripts/postinstall.mts",
    "typecheck": "npm run make-i18n && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "lint": "eslint src",
    "make-i18n": "node scripts/make-i18n-translations.cjs",
    "sprite-mark:sync": "tsx scripts/sync-sprite-mark-library.mts",
    "check-translation-completeness": "node scripts/check-translation-completeness.cjs",
    "i18n:migrate": "node scripts/i18n-bulk-migrate.cjs --write && node scripts/i18n-migrate-props.cjs && node scripts/i18n-fix-imports.cjs && node scripts/i18n-normalize.cjs && node scripts/i18n-clean-stale-hooks.cjs && npm run make-i18n",
    "test": "tsx --test server/automations/*.test.ts server/stores/automationStore.test.ts server/openhands/openhandsAgent.test.ts",
    "ops:mcp": "node --import tsx/esm scripts/kosmos-ops-mcp.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@openhands/typescript-client": "^1.32.1",
    "@openuidev/lang-core": "^0.2.7",
    "@openuidev/react-headless": "^0.9.1",
    "@openuidev/react-lang": "^0.2.8",
    "@openuidev/react-ui": "^0.12.1",
    "@pipecat-ai/client-js": "^1.12.0",
    "@pipecat-ai/small-webrtc-transport": "^1.10.5",
    "@zed-industries/agent-client-protocol": "^0.4.5",
    "better-sqlite3": "^12.0.0",
    "hono": "^4.12.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "monaco-editor": "^0.55.1",
    "node-cron": "^4.5.0",
    "openai": "^6.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.3.0"
  },
  "engines": {
    "node": ">=22"
  }
}
