{
  "name": "arco-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Arco OS — a generative AI operating system prototype. Desktop shell + agent that builds adaptive live apps.",
  "workspaces": [
    "model-manager",
    "packages/app-sdk",
    "packages/editor-kit",
    "apps/desktop",
    "apps/docs",
    "apps/www",
    "apps/arco-docs"
  ],
  "scripts": {
    "models": "npm run dev -w model-manager",
    "generate": "tsx scripts/generate-prompts.ts",
    "predev": "npm run build:apps",
    "dev": "concurrently -n server,web -c yellow,cyan \"npm run dev:server\" \"npm run dev:web\"",
    "dev:all": "concurrently -n server,web,voice -c yellow,cyan,magenta \"npm run dev:server\" \"npm run dev:web\" \"npm run voice\"",
    "dev:www": "npm run dev -w @kosmos/www",
    "dev:arco-docs": "npm run dev -w @arco/docs-site",
    "dev:site": "concurrently -n www,docs -c green,blue \"npm run dev:www\" \"npm run dev:arco-docs\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "voice": "cd voice-server && .venv/bin/python bot.py --host localhost --port 4630",
    "build:apps": "npm run build -w @arco/docs-app",
    "build:www": "npm run build -w @kosmos/www",
    "build:arco-docs": "npm run build -w @arco/docs-site",
    "build": "npm run build:apps && npm run build:www && npm run build:arco-docs && vite build",
    "desktop": "npm run build && npm run start -w @arco/desktop",
    "desktop:dev": "concurrently -n web,desktop -c cyan,magenta \"npm run dev:web\" \"npm run dev -w @arco/desktop\"",
    "desktop:dev:all": "concurrently -n server,web,desktop -c yellow,cyan,magenta \"npm run dev:server\" \"npm run dev:web\" \"npm run dev -w @arco/desktop\"",
    "start": "NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "test": "tsx --test server/automations/*.test.ts server/stores/automationStore.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@openuidev/lang-core": "^0.2.7",
    "@openuidev/react-headless": "^0.9.1",
    "@openuidev/react-lang": "^0.2.8",
    "@openuidev/react-ui": "^0.12.1",
    "@pipecat-ai/client-js": "^1.12.0",
    "@pipecat-ai/small-webrtc-transport": "^1.10.5",
    "@zed-industries/agent-client-protocol": "^0.4.5",
    "better-sqlite3": "^12.0.0",
    "hono": "^4.12.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "monaco-editor": "^0.55.1",
    "node-cron": "^4.5.0",
    "openai": "^6.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "engines": {
    "node": ">=22"
  }
}
